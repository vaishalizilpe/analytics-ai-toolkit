# ── LLM Provider Configuration ───────────────────────────────────────────────
# Set LLM_PROVIDER to switch models. No other code changes needed.
# Options: claude (default), openai, deepseek, gemini

LLM_PROVIDER=claude

# Optional: override the default model for the chosen provider.
# Leave blank to use the provider default.
# claude default:   claude-sonnet-4-6
# openai default:   gpt-4o
# deepseek default: deepseek-chat
# gemini default:   gemini-1.5-pro
LLM_MODEL=

# ── API Keys (only the key for your chosen provider is required) ──────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
